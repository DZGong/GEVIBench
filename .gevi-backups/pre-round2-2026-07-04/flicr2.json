  "dynamicRangeData": [
    {
      "deltaF": 12.9,
      "sign": "positive",
      "modality": "1P",
      "source": "doi:10.1038/s41592-018-0188-7",
      "note": "1P ΔF/F = 12.9 ± 1.3% for a 120-mV depolarizing step in HEK cells (voltage clamp, 561 nm laser, 50 mW/mm², n = 6 cells), stated in the main text / Supplementary Note 2 and shown in the FlicR1-vs-FlicR2 ΔF/ΔV plot (Fig. S2e, dark-brown FlicR2 curve reaching ~13% at +50 mV); FlicR2 was engineered to ~2x the sensitivity of FlicR1 (6.4 ± 1.0%/120 mV). This is the full 120-mV value (Kannan's depolarization steps run -70→+50 mV); the -70→+30 mV (100-mV) chord read off Fig. S2e is ~10.8%. CORRECTED from a prior 24% that was mis-attributed to the normalized trace figure Fig. 2c — which is normalized to 1.0 and cannot yield an absolute ΔF/F — and merely duplicated the VADER1 2P value below. FlicR2's 2P ΔF/F is genuinely ~2x larger (see the 2P entry / the VADER1 F-V curve).",
      "sourceFigure": "Fig. S2e",
      "proofread": false
    },
    {
      "deltaF": 24,
      "sign": "positive",
      "modality": "2P",
      "source": "doi:10.64898/2026.06.01.726307",
      "note": "2P ΔF/F ≈ 24% across a -70 → +30 mV (100-mV) step, read directly from the steady-state F-V curve (Fig. 2D: 0% at -70 mV, ~+20-24% at +30 mV for the gray FlicR2 curve; VADER1-vs-FlicR2 comparison). The paper's own headline FlicR2 number is 19 ± 11% ΔF/F, but that is the narrower -40→+30 mV (70-mV) suprathreshold window quantified in Fig. 2E; the 100-mV -70→+30 chord off Fig. 2D is slightly larger, hence ~24%. Yang et al. 2026; whole-cell voltage clamp, 2P imaging at 1050 nm, ~22°C.",
      "sourceFigure": "Fig. 2D",
